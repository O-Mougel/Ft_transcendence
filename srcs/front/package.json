{
  "name": "ft_transcendance",
  "version": "1.0",
  "description": "very cool project",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "build:css": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css",
    "build": "npm run build:ts && npm run build:css",
    "watch:ts": "tsc -p tsconfig.json --watch",
    "watch:css": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css --watch",
    "dev": "concurrently \"npm:watch:ts\" \"npm:watch:css\"",
    "start": "npm run build"
  },
  "devDependencies": {
	"@tailwindcss/cli": "4.1.16",
	"body-parser": "2.2.0",
	"browser-sync": "3.0.4",
	"fastify": "5.6.1",
	"nodemon": "3.1.10",
	"ts-node": "10.9.2",
	"tailwindcss": "4.1.16",
	"typescript": "4.9.3",
	"@fastify/websocket": "11.2.0",
	"@types/ws": "8.18.1",
	"concurrently": "7.6.0",
	"yup": "1.7.1"
},
	"dependencies": {
	"@fastify/static": "8.3.0",
	"chart.js": "4.5.1"
  }
}
