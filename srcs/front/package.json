{
  "name": "ft_transcendance",
  "version": "1.0",
  "description": "very cool project",
  "scripts": {
	"build:ts": "tsc -p tsconfig.json",
	"build:views": "tsc -p tsconfig.views.json",
	"build:game": "tsc -p tsconfig.game.json",
	"build:css": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css",
	"build": "npm run build:ts && npm run build:views && npm run build:game && npm run build:css",

	"watch:ts": "tsc -p tsconfig.json --watch",
	"watch:views": "tsc -p tsconfig.views.json --watch",
	"watch:game": "tsc -p tsconfig.game.json --watch",
	"watch:css": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css --watch",

	"dev": "concurrently \"npm:watch:ts\" \"npm:watch:views\" \"npm:watch:game\" \"npm:watch:css\"",

	"start": "npm run dev"
  },
  "devDependencies": {
	"@tailwindcss/cli": "4.1.16",
	"body-parser": "2.2.0",
	"browser-sync": "3.0.4",
	"fastify": "5.6.1",
	"nodemon": "3.1.10",
	"ts-node": "10.9.2",
	"tailwindcss": "4.1.16",
	"typescript": "4.9.3",
	"concurrently": "7.6.0"
},
	"dependencies": {
	"@fastify/static": "8.3.0"
  }
}
