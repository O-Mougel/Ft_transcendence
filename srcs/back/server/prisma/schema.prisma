// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  name             String   @unique
  password         String   
  salt	           String   
  avatar           String   @default("src/img/userPfp/default.png")
  friends          User[]   @relation("UserFriends")
  friendOf         User[]   @relation("UserFriends")
  request          User[]   @relation("FriendRequest")
  requestOf        User[]   @relation("FriendRequest")
  auth2fa          Boolean  @default(false)
  twofasecret      String?
  online           Boolean  @default(false)
  aiInvited        Boolean  @default(false)
  matchesAsPlayer1 Match[]  @relation("Player1Matches")
  matchesAsPlayer2 Match[]  @relation("Player2Matches")
  createdAt        DateTime @default(now())
}

model Match {
  id            Int      @id @default(autoincrement())
  player1Id     Int
  player2Id     Int      @default(0) //AI/Invited player as default
  player1       User     @relation("Player1Matches", fields: [player1Id], references: [id])
  player2       User     @relation("Player2Matches", fields: [player2Id], references: [id])
  player1Score  Int
  player2Score  Int
  winnerId	    Int
  longestStreak Int
  duration		Int
  finish        Boolean	 //false = aborted/true = finnished
  type          String   //'tournament', 'ranked', '1v1', '2v2', 'AI'
  player2name   String?  @default("") //'AI' or login of the invited player
  round         String?  @default("") //for the tournament 'Final' 'Semifinal' 'Quaterfinal' 'Octofinals' '16th-finals'
  player3name   String?  @default("") //for 2v2 login of the invited player
  player4name   String?  @default("") //for 2v2 login of the invited player
  createdAt     DateTime @default(now())
}

model refreshTokens {
	id         Int		@id @default(autoincrement())
	user_id    Int
	token      String   @unique	
	expires_at DateTime
	created_at DateTime @default(now())
}
