{
  "name": "ft_transcendance",
  "version": "1.0",
  "description": "very cool project",
  "main": "index.js",
  "scripts": {
    "dev:tw": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css --watch",
    "dev:ts": "nodemon server.js",
    "dev:bs": "browser-sync start --server 'src' --files 'src/**/*' --no-ui --port 3000 --reload-delay 10",
    "build": "tsc",
	"start": "node src/server.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.1.16",
    "body-parser": "2.2.0",
    "browser-sync": "3.0.4",
    "fastify": "5.6.1",
    "nodemon": "3.1.10",
    "ts-node": "10.9.2",
	"tailwindcss": "4.1.16",
    "typescript": "4.9.3"
},
	"dependencies": {
    "@fastify/static": "8.3.0"
  }
}
