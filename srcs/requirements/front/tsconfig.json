{
  "compilerOptions": {
    "target": "ES2020",                          // Emit JavaScript targeting ES2020 features (async/await, etc.)
    "module": "nodenext",                        
    "moduleResolution": "nodenext",                        
	"sourceMap": true,
	"skipLibCheck": true,
    "outDir": "./src/js",                            // Write compiled .js files into the "dist" folder
  },
  "include": ["./src/**/*.ts"],                     // Files to include (glob relative to this tsconfig). Matches files under src
}